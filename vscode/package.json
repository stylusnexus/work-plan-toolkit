        "title": "Close Track",
        "category": "Work Plan"
      },
      {
        "command": "workPlan.move",
        "title": "Move Issue from Track",
        "category": "Work Plan"
      },
      {
        "command": "workPlan.renameTrack",
        "title": "Rename Track",
        "category": "Work Plan"
      },
      {
        "command": "workPlan.markCleanup",
        "title": "Mark for Cleanup",
        "category": "Work Plan"
      },
      {
        "command": "workPlan.unmarkCleanup",
        "title": "Unmark Cleanup",
        "category": "Work Plan"
      },
      {
        "command": "workPlan.archiveTrack",
        "title": "Archive Track",
        "category": "Work Plan"
      },
      {
        "command": "workPlan.unarchiveTrack",
        "title": "Unarchive Track",
        "category": "Work Plan"
      },
      {
