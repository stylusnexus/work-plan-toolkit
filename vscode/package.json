{
  "name": "work-plan-viewer",
  "displayName": "Work Plan",
  "publisher": "stylusnexus",
  "version": "0.2.1",
  "description": "Sidebar tree for your GitHub issues across repos, organised into tracks — with a Mermaid dependency graph, per-track detail panel, and full read/write (slot, close, edit, new track, refresh, reconcile, hygiene). Shared tracks sync via git; private tracks stay local. Public-repo writes are gated behind a confirm dialog — no accidental leaks.",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/stylusnexus/work-plan-toolkit.git",
    "directory": "vscode"
  },
  "bugs": {
    "url": "https://github.com/stylusnexus/work-plan-toolkit/issues"
  },
  "homepage": "https://github.com/stylusnexus/work-plan-toolkit/tree/main/vscode#readme",
  "keywords": [
    "work-plan",
    "github issues",
    "project planning",
    "tracks",
    "mermaid",
    "dependency graph",
    "issue tracker",
    "kanban"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "workPlan",
          "title": "Work Plan",
          "icon": "media/work-plan.svg"
        }
      ]
    },
    "views": {
      "workPlan": [
        {
          "id": "workPlan.tree",
          "name": "Tracks"
        }
      ]
    },
    "commands": [
      {
        "command": "workPlan.refresh",
        "title": "Work Plan: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "workPlan.selectView",
        "title": "Work Plan: Select View",
        "icon": "$(filter)"
      },
      {
        "command": "workPlan.sortTracks",
        "title": "Work Plan: Sort Tracks",
        "icon": "$(sort-precedence)"
      },
      {
        "command": "workPlan.openTrack",
        "title": "Open Track"
      },
      {
        "command": "workPlan.openIssue",
        "title": "Open Issue"
      },
      {
        "command": "workPlan.editFields",
        "title": "Work Plan: Edit Track Fields"
      },
      {
        "command": "workPlan.setNext",
        "title": "Work Plan: Set Next-Up"
      },
      {
        "command": "workPlan.refreshMd",
        "title": "Work Plan: Refresh Track Body"
      },
      {
        "command": "workPlan.reconcile",
        "title": "Work Plan: Reconcile (preview)"
      },
      {
        "command": "workPlan.hygiene",
        "title": "Work Plan: Run Hygiene"
      },
      {
        "command": "workPlan.slot",
        "title": "Work Plan: Slot Issue into Track"
      },
      {
        "command": "workPlan.close",
        "title": "Work Plan: Close Track"
      },
      {
        "command": "workPlan.newTrack",
        "title": "Work Plan: New Track"
      },
      {
        "command": "workPlan.addRepo",
        "title": "Work Plan: Add Repo"
      },
      {
        "command": "workPlan.setNotesLocation",
        "title": "Work Plan: Set Notes Location"
      },
      {
        "command": "workPlan.slotUntracked",
        "title": "Work Plan: Slot Untracked Issue into Track"
      },
      {
        "command": "workPlan.batchSlotUntracked",
        "title": "Work Plan: Batch Slot Untracked Issues into Track"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "workPlan.refresh",
          "when": "view == workPlan.tree",
          "group": "navigation"
        },
        {
          "command": "workPlan.selectView",
          "when": "view == workPlan.tree",
          "group": "navigation"
        },
        {
          "command": "workPlan.sortTracks",
          "when": "view == workPlan.tree",
          "group": "navigation"
        },
        {
          "command": "workPlan.hygiene",
          "when": "view == workPlan.tree",
          "group": "9_maintenance"
        },
        {
          "command": "workPlan.newTrack",
          "when": "view == workPlan.tree",
          "group": "2_workPlanCreate"
        },
        {
          "command": "workPlan.addRepo",
          "when": "view == workPlan.tree",
          "group": "2_workPlanCreate@2"
        },
        {
          "command": "workPlan.setNotesLocation",
          "when": "view == workPlan.tree",
          "group": "8_workPlanConfig"
        }
      ],
      "view/item/context": [
        {
          "command": "workPlan.editFields",
          "when": "view == workPlan.tree && viewItem == workPlanTrack",
          "group": "1_workPlanWrite@1"
        },
        {
          "command": "workPlan.setNext",
          "when": "view == workPlan.tree && viewItem == workPlanTrack",
          "group": "1_workPlanWrite@2"
        },
        {
          "command": "workPlan.refreshMd",
          "when": "view == workPlan.tree && viewItem == workPlanTrack",
          "group": "1_workPlanWrite@3"
        },
        {
          "command": "workPlan.reconcile",
          "when": "view == workPlan.tree && viewItem == workPlanTrack",
          "group": "1_workPlanWrite@4"
        },
        {
          "command": "workPlan.slot",
          "when": "view == workPlan.tree && viewItem == workPlanTrack",
          "group": "1_workPlanWrite@5"
        },
        {
          "command": "workPlan.close",
          "when": "view == workPlan.tree && viewItem == workPlanTrack",
          "group": "1_workPlanWrite@6"
        },
        {
          "command": "workPlan.slotUntracked",
          "when": "view == workPlan.tree && viewItem == workPlanUntrackedIssue",
          "group": "1_workPlanWrite@1"
        },
        {
          "command": "workPlan.batchSlotUntracked",
          "when": "view == workPlan.tree && viewItem == workPlanUntrackedGroup",
          "group": "1_workPlanWrite@1"
        }
      ],
      "commandPalette": [
        {
          "command": "workPlan.slotUntracked",
          "when": "false"
        },
        {
          "command": "workPlan.batchSlotUntracked",
          "when": "false"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "workPlan.tree",
        "when": "workPlanHasRepos == false",
        "contents": "No work-plan repos yet.\n\n[Add a repo](command:workPlan.addRepo)\n\nNew here? Choose where your private track notes live first.\n[Set notes location](command:workPlan.setNotesLocation)"
      }
    ],
    "configuration": {
      "title": "Work Plan",
      "properties": {
        "workPlan.cliPath": {
          "type": "string",
          "default": "work-plan",
          "description": "Path to the work-plan CLI launcher (on PATH by default)."
        },
        "workPlan.expandReposByDefault": {
          "type": "boolean",
          "default": false,
          "description": "Expand all repo groups in the Tracks view on load. Off by default (repos start collapsed); a single-repo workspace always expands."
        },
        "workPlan.autoRefreshInterval": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "enum": [0, 30, 60, 300, 900],
          "enumDescriptions": [
            "Off — manual refresh only",
            "Every 30 seconds",
            "Every minute",
            "Every 5 minutes",
            "Every 15 minutes"
          ],
          "description": "Auto-refresh interval in seconds (0 = off). Silently re-polls the CLI in the background — useful when teammates are pushing shared-track changes."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit -p ./",
    "test": "node --test --experimental-strip-types --no-warnings=MODULE_TYPELESS_PACKAGE_JSON \"src/**/*.test.ts\"",
    "package": "vsce package --no-dependencies -o work-plan-viewer.vsix",
    "publish:vsce": "vsce publish --packagePath work-plan-viewer.vsix --skip-duplicate",
    "publish:ovsx": "ovsx publish work-plan-viewer.vsix",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.25.0",
    "ovsx": "^0.10.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "mermaid": "^11.15.0"
  }
}
