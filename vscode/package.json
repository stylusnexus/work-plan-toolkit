          "group": "9_workPlanRepoDanger@2"
        },
        {
          "command": "workPlan.openTrackFile",
          "when": "view == workPlan.tree && viewItem == workPlanTrack",
          "group": "0_workPlanNav@1"
        },
        {
          "command": "workPlan.orient",
          "when": "view == workPlan.tree && viewItem == workPlanTrack",
          "group": "0_workPlanSession@1"
        },
        {
          "command": "workPlan.handoff",
