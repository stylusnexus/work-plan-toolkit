{
  "name": "work-plan-viewer",
  "displayName": "Work Plan",
  "publisher": "stylusnexus",
  "version": "0.19.0",
  "description": "Browse and manage GitHub issues as tracks — dependency graph, per-track detail, and read/write (slot, move, reconcile, close) in the sidebar.",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/stylusnexus/work-plan-toolkit.git",
    "directory": "vscode"
  },
  "bugs": {
    "url": "https://github.com/stylusnexus/work-plan-toolkit/issues"
  },
  "homepage": "https://github.com/stylusnexus/work-plan-toolkit/tree/main/vscode#readme",
  "keywords": [
    "work-plan",
    "github issues",
    "project planning",
    "tracks",
    "mermaid",
    "dependency graph",
    "issue tracker",
    "kanban"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "main": "./dist/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false
    }
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "workPlan",
          "title": "Work Plan",
          "icon": "media/work-plan.svg"
        }
      ]
    },
    "views": {
      "workPlan": [
        {
          "id": "workPlan.tree",
          "name": "Tracks"
        },
        {
          "id": "workPlan.plans",
          "name": "Plans",
          "visibility": "collapsed"
        }
      ]
    },
    "commands": [
      {
        "command": "workPlan.refresh",
        "title": "Refresh",
        "category": "Work Plan",
        "icon": "$(refresh)"
      },
      {
        "command": "workPlan.selectView",
        "title": "Select View",
        "category": "Work Plan",
        "icon": "$(filter)"
      },
      {
        "command": "workPlan.sortTracks",
        "title": "Sort Tracks",
        "category": "Work Plan",
        "icon": "$(sort-precedence)"
      },
      {
        "command": "workPlan.showAllRepos",
        "title": "Show All Repos",
        "category": "Work Plan"
      },
      {
        "command": "workPlan.focusCurrentRepo",
        "title": "Focus Current Repo",
        "category": "Work Plan"
      },
      {
        "command": "workPlan.openSettings",
