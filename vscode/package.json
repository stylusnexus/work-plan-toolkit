          "command": "workPlan.close",
          "when": "view == workPlan.tree && viewItem == workPlanTrack",
          "group": "9_workPlanDanger@1"
        },
        {
          "command": "workPlan.renameTrack",
          "when": "view == workPlan.tree && viewItem == workPlanTrack",
          "group": "9_workPlanDanger@2"
        },
        {
          "command": "workPlan.markCleanup",
          "when": "view == workPlan.tree && viewItem == workPlanTrack",
          "group": "9_workPlanDanger@3"
        },
        {
          "command": "workPlan.unmarkCleanup",
          "when": "view == workPlan.tree && viewItem == workPlanTrack",
          "group": "9_workPlanDanger@4"
        },
        {
          "command": "workPlan.archiveTrack",
          "when": "view == workPlan.tree && viewItem == workPlanTrack",
          "group": "9_workPlanDanger@5"
        },
        {
          "command": "workPlan.unarchiveTrack",
          "when": "view == workPlan.tree && viewItem == workPlanTrackArchived",
          "group": "9_workPlanDanger@1"
        },
        {
          "command": "workPlan.deleteTrack",
          "when": "view == workPlan.tree && viewItem =~ /^workPlanTrack(Archived)?$/",
          "group": "9_workPlanDanger@6"
