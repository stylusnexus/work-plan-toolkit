        },
        {
          "command": "workPlan.plans.clearBaseline",
          "when": "view == workPlan.plans && viewItem =~ /baselined/",
          "group": "3_baseline"
        },
        {
          "command": "workPlan.plans.confirmVerdict",
          "when": "view == workPlan.plans && (viewItem =~ /^workPlanPlan-/ || viewItem == workPlanAckedPlan)",
          "group": "2_confirm"
        },
        {
          "command": "workPlan.plans.clearConfirmation",
          "when": "view == workPlan.plans && viewItem == workPlanPlanConfirmed",
          "group": "2_confirm"
        },
        {
          "command": "workPlan.plans.archive",
