      {
        "view": "workPlan.tree",
        "when": "workPlanGitHubAuthed == no-cli",
        "contents": "work-plan CLI not found.\n\nThe Work Plan viewer drives a separate command-line tool, `work-plan`, which isn't on this machine's PATH. Installing the extension does not install the CLI — they're separate.\n\nIf you opened this folder in WSL or a remote (the window shows e.g. “WSL: …” at bottom-left), install the CLI in THAT environment, not on the host:\n\n`npm install -g @stylusnexus/work-plan`\n\n[Install instructions](https://github.com/stylusnexus/work-plan-toolkit#install)\n\nAlready installed it? (reload the window if you just did)\n[Retry](command:workPlan.checkGitHubAuth)"
      },
      {
        "view": "workPlan.tree",
        "when": "workPlanGitHubAuthed == no-gh",
        "contents": "GitHub CLI not found.\n\nWork Plan reads issue state through the GitHub CLI (gh), which isn't installed or isn't on your PATH.\n\n[Install the GitHub CLI](command:workPlan.openGhInstallDocs)\n\nAlready installed it?\n[Retry](command:workPlan.checkGitHubAuth)"
      },
      {
        "view": "workPlan.tree",
        "when": "workPlanGitHubAuthed == false",
        "contents": "Not signed in to GitHub.\n\nWork Plan can't read issue state until you sign in with the GitHub CLI. Tracks and issue counts stay hidden until then — they aren't empty, just unauthenticated.\n\n[Sign in to GitHub](command:workPlan.signInToGitHub)\n\nFinished signing in?\n[Retry](command:workPlan.checkGitHubAuth)"
      },
      {
        "view": "workPlan.tree",
        "when": "workPlanGitHubAuthed == probe-error",
        "contents": "Couldn't verify GitHub sign-in.\n\nThe `work-plan` CLI ran but didn't return a result, so Work Plan can't tell whether you're signed in. This is usually a missing CLI dependency, not a GitHub problem — the CLI needs `gh`, `git`, and `yq` (the Go mikefarah/yq) on the same PATH the editor runs in.\n\nCheck dependencies, then:\n[Retry](command:workPlan.checkGitHubAuth)\n\n[Install instructions](https://github.com/stylusnexus/work-plan-toolkit#install)"
      },
      {
        "view": "workPlan.tree",
        "when": "workPlanGitHubAuthed != false && workPlanGitHubAuthed != no-gh && workPlanGitHubAuthed != no-cli && workPlanGitHubAuthed != probe-error && workPlanLoadError != true && workPlanConfigured == false",
        "contents": "No work-plan repos yet.\n\n[Add a repo](command:workPlan.addRepo)\n\nNew here? Choose where your private track notes live first.\n[Set notes location](command:workPlan.setNotesLocation)"
      },
      {
        "view": "workPlan.tree",
        "when": "workPlanGitHubAuthed != false && workPlanGitHubAuthed != no-gh && workPlanGitHubAuthed != no-cli && workPlanGitHubAuthed != probe-error && workPlanLoadError != true && workPlanConfigured == true && workPlanHasTracks == false",
        "contents": "No tracks yet.\n\n[Refresh](command:workPlan.refresh)\n\nAdd issues to a track from the terminal with `work-plan slot`, or create a new track with `work-plan init-repo`."
      },
      {
        "view": "workPlan.tree",
        "when": "workPlanGitHubAuthed != false && workPlanGitHubAuthed != no-gh && workPlanGitHubAuthed != no-cli && workPlanGitHubAuthed != probe-error && workPlanLoadError == true",
        "contents": "Couldn't load work plan.\n\n[Retry](command:workPlan.checkGitHubAuth)"
      }
    ],
    "configuration": {
      "title": "Work Plan",
      "properties": {
        "workPlan.cliPath": {
          "type": "string",
          "default": "work-plan",
          "scope": "machine",
          "description": "Path to the work-plan CLI launcher (on PATH by default). Machine-scoped: cannot be overridden by a workspace .vscode/settings.json, so a malicious repo cannot redirect the spawned executable."
        },
        "workPlan.expandReposByDefault": {
          "type": "boolean",
          "default": false,
          "description": "Expand all repo groups in the Tracks view on load. Off by default (repos start collapsed); a single-repo workspace always expands."
        },
        "workPlan.autoFocusRepo": {
          "type": "boolean",
          "default": false,
          "description": "When the open workspace folder is a configured repo, default the Tracks view's lens to that repo (so you don't read another repo's issues by accident). Resolved by clone path, then git remote. Off by default — the Tracks view shows every repo; turn on to focus the current workspace's repo. A manual lens choice always wins, and the toolbar toggle flips this live without a reload."
        },
        "workPlan.autoRefreshInterval": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "enum": [
            0,
            30,
            60,
            300,
            900
          ],
          "enumDescriptions": [
            "Off — manual refresh only",
            "Every 30 seconds",
            "Every minute",
            "Every 5 minutes",
            "Every 15 minutes"
          ],
          "description": "Auto-refresh interval in seconds (0 = off). Silently re-polls the CLI in the background — useful when teammates are pushing shared-track changes."
        },
        "workPlan.showNextUpPreset": {
          "type": "boolean",
          "default": true,
          "description": "Show the active next-up ordering preset in the track detail panel. Hidden automatically when the track has no preset set (older CLI or preset not configured)."
        },
        "workPlan.stallDays": {
          "type": "string",
          "enum": [
            "match",
            "14",
            "30",
            "45",
            "60",
            "90"
          ],
          "enumDescriptions": [
            "Match the CLI (config.yml / 14)",
            "14 days",
            "30 days",
            "45 days",
            "60 days",
            "90 days"
          ],
          "default": "match",
          "description": "How cold a plan's build (its declared files) must be to read as 'stalled' in the Plans view."
        },
        "workPlan.plansAutoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Auto-update the Plans view when a scanned repo's git activity changes (e.g. committing a plan's declared files clears its 'stalled' state) without a manual Refresh. Watches each expanded repo's .git refs; falls back to manual refresh when off."
        },
        "workPlan.autoSlotConfidenceThreshold": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence cutoff for a clear-margin suggestion to land in the one-click 'Suggested' bucket (vs 'Needs review'). 0–1; higher means fewer one-click accepts. Default 0.7."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit -p ./",
    "test": "node --test --experimental-strip-types --no-warnings=MODULE_TYPELESS_PACKAGE_JSON \"src/**/*.test.ts\"",
    "package": "vsce package --no-dependencies -o work-plan-viewer.vsix",
    "publish:vsce": "vsce publish --packagePath work-plan-viewer.vsix --skip-duplicate",
    "publish:ovsx": "ovsx publish work-plan-viewer.vsix",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.28.0",
    "ovsx": "^0.10.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "mermaid": "^11.15.0"
  }
}
